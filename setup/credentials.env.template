# credentials.env.template — reference only. DO NOT fill in real values here or
# commit a filled copy. The real ~/.designer/credentials.env is generated at
# session start by setup/session-start.sh from environment secrets.
#
# Secrets model: ONE environment secret. Everything else lives in GCP Secret
# Manager and is fetched at session start by setup/fetch-secrets.mjs.
#
# Set this ONE value as an ENVIRONMENT SECRET in each Claude Code environment:

GCP_CLAUDE_DRIVER_SA_JSON= # full JSON of claude-driver@otchealth-shared-prod SA

# These live in GCP Secret Manager (project otchealth-shared-prod), NOT here:
#   secret 'openai-api-key'      -> OPENAI_API_KEY
#   secret 'elevenlabs-api-key'  -> ELEVENLABS_API_KEY
#   secret 'recraft-api-key'     -> RECRAFT_API_KEY  (optional)
# You MAY still pass OPENAI_API_KEY / ELEVENLABS_API_KEY directly as env vars
# to override Secret Manager (handy for local dev).

# Optional overrides (sensible defaults applied if unset):
GOOGLE_CLOUD_PROJECT=otchealth-shared-prod
VERTEX_DEFAULT_IMAGEN_MODEL=imagen-4.0-generate-001
VERTEX_DEFAULT_VIDEO_MODEL=veo-2.0-generate-001
VERTEX_DEFAULT_LLM_MODEL=gemini-2.5-flash
RECRAFT_API_KEY=
