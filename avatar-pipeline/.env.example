# Copy to .env for local sandbox build/test. .env is gitignored.
# In GitHub Actions these come from repository Actions Secrets instead.

# ElevenLabs
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# Cloudflare R2 (S3-compatible). Endpoint is built from the account id.
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ACCOUNT_ID=
R2_BUCKET=
R2_PUBLIC_URL_BASE=

# Notion
NOTION_API_KEY=
NOTION_RENDER_DB_ID=

# Azure (for the GitHub Actions azure/login step this is the AZURE_CREDENTIALS json;
# locally you can also use a logged-in az session)
AZURE_RG=otchealth-avatar-rg
AZURE_VM_NAME=otchealth-avatar-gpu
AZURE_REGION=eastus
AZURE_VM_SKU=Standard_NC4as_T4_v3

# Container image (built and pushed to GHCR by the build-image workflow)
GHCR_IMAGE=ghcr.io/gbgolfmatt/otchealth-avatar:latest

# Optional paid fallback
FAL_KEY=
