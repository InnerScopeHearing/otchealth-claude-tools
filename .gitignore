# Node deps (installed by setup/session-start.sh at session start)
node_modules/
package-lock.json

# NEVER commit real credentials
credentials.env
*.credentials.env
.designer/
.gcp_*.json
*-sa.json
gcp-*-sa.json
*.pem
*.p12

# Generated assets (designer output lands in project repos, not here)
assets/generated/
*.log
.DS_Store

# COO confidential runtime notes — sensitive specifics never go in git
*.local.md
coo/CONFIDENTIAL*

# Per-environment Claude Code overrides (e.g. KB_AGENT). Environment-scoped, not repo-wide —
# committing would force one agent's memory lane on every agent that shares this repo.
.claude/settings.local.json
